# Lycet - Carmencita Express
# Copia este archivo como .env para desarrollo local.
# En Render, configura estas variables en Environment Variables.
# No subas credenciales reales, certificados privados ni tokens reales.

APP_ENV=prod
APP_SECRET=change_me_for_a_long_random_secret
PORT=8000

# Token que debe coincidir con LYCET_CLIENT_TOKEN en el backend FastAPI.
CLIENT_TOKEN=change_me_lycet_token

# Credenciales SOL. SOL_USER es RUC + usuario SOL.
SOL_USER=20161515648MODDATOS
SOL_PASS=MODDATOS

# Rutas SUNAT beta para comprobantes.
FE_URL=https://e-beta.sunat.gob.pe/ol-ti-itcpfegem-beta/billService
RE_URL=https://e-beta.sunat.gob.pe/ol-ti-itemision-otroscpe-gem-beta/billService
GUIA_URL=https://e-beta.sunat.gob.pe/ol-ti-itemision-guia-gem-beta/billService

# Rutas GRE beta.
AUTH_URL=https://gre-test.nubefact.com/v1
API_URL=https://gre-test.nubefact.com/v1
CLIENT_ID=test-85e5b0ae-255c-4891-a595-0b98c65c9854
CLIENT_SECRET=test-Hty/M6QshYvPgItX2P0+Kw==

# Docker image config.
